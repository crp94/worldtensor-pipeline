# Credential template for WorldTensor data acquisition.
# Copy this file to secrets.yml and fill in your credentials.
#
#   cp config/secrets.yml.example config/secrets.yml
#
# secrets.yml is listed in .gitignore and must NEVER be committed.

# Copernicus Climate Data Store (ERA5, CAMS, drought indices)
# Register at: https://cds.climate.copernicus.eu/
cds:
  url: https://cds.climate.copernicus.eu/api
  key: YOUR-CDS-API-KEY-HERE

# NASA Earthdata (MODIS, GRACE, GPW, GLDAS, etc.)
# Register at: https://urs.earthdata.nasa.gov/
# You can use either a Bearer token OR username/password.
earthdata:
  token: YOUR-EARTHDATA-TOKEN-HERE
  # username: YOUR-EARTHDATA-USERNAME
  # password: YOUR-EARTHDATA-PASSWORD

# Zenodo (dataset upload only — not needed for processing)
# Create a token at: https://zenodo.org/account/settings/applications/
zenodo:
  token: YOUR-ZENODO-TOKEN-HERE
